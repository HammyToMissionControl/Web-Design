@model Auth.Models.Product


<h1>This is the form page</h1>


<form asp-action="createProduct" method="post" enctype="multipart/form-data">
    <div>
        <label>Product Image</label>
        <input type="file" name="ImageFile" accept="image/*">
    </div>
    <div>
        <label asp-for="Name"></label>
        <input asp-for="Name">
        <span asp-validation-for="Name" style="color:red"></span>
    </div>
    <div>
        <label asp-for="Description"></label>
        <input asp-for="Description">
    </div>

    <div>
        <label asp-for="Price"></label>
        <input asp-for="Price" type="number" step="0.01" min="0">
        <span asp-validation-for="Price" style="color:red"></span>
    </div>
    <div>
        <label asp-for="Quantity"></label>
        <input asp-for="Quantity" type="number" step="1" min="0">
        <span asp-validation-for="Quantity" style="color:red"></span>
    </div>
    <div>
        <label asp-for="CategoryId"></label>
        <select asp-for="CategoryId" asp-items="ViewBag.Categories">
            <option value="">Select an option</option>
        </select>
        <span asp-validation-for="CategoryId" style="color:red"></span>

    </div>

    <button type="submit">Create button</button>

    <div asp-validation-summary="All" style="color:red"></div>
</form> 